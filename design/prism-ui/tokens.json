{
  "name": "Prism UI",
  "version": "1.0.0",
  "description": "Enterprise design system for the Prism product suite",
  "color": {
    "light": {
      "background": { "primary": "#FFFFFF", "secondary": "#F8FAFC", "tertiary": "#F1F5F9", "inverse": "#0F172A" },
      "text": { "primary": "#0F172A", "secondary": "#475569", "tertiary": "#94A3B8", "inverse": "#FFFFFF", "link": "#2563EB" },
      "border": { "default": "#E2E8F0", "strong": "#CBD5E1", "focus": "#2563EB" },
      "brand": { "primary": "#2563EB", "primaryHover": "#1D4ED8", "primarySubtle": "#EFF6FF" },
      "semantic": {
        "success": "#059669",
        "successSubtle": "#ECFDF5",
        "warning": "#D97706",
        "warningSubtle": "#FFFBEB",
        "error": "#DC2626",
        "errorSubtle": "#FEF2F2",
        "info": "#0284C7",
        "infoSubtle": "#F0F9FF"
      }
    },
    "dark": {
      "background": { "primary": "#0F172A", "secondary": "#1E293B", "tertiary": "#334155", "inverse": "#F8FAFC" },
      "text": { "primary": "#F8FAFC", "secondary": "#CBD5E1", "tertiary": "#64748B", "inverse": "#0F172A", "link": "#60A5FA" },
      "border": { "default": "#334155", "strong": "#475569", "focus": "#60A5FA" },
      "brand": { "primary": "#3B82F6", "primaryHover": "#60A5FA", "primarySubtle": "#1E3A5F" },
      "semantic": {
        "success": "#34D399",
        "successSubtle": "#064E3B",
        "warning": "#FBBF24",
        "warningSubtle": "#78350F",
        "error": "#F87171",
        "errorSubtle": "#7F1D1D",
        "info": "#38BDF8",
        "infoSubtle": "#0C4A6E"
      }
    }
  },
  "typography": {
    "fontFamily": { "sans": "Inter", "mono": "JetBrains Mono" },
    "scale": {
      "display-lg": { "size": 48, "lineHeight": 56, "weight": 600, "letterSpacing": -0.02 },
      "display-md": { "size": 36, "lineHeight": 44, "weight": 600, "letterSpacing": -0.02 },
      "heading-lg": { "size": 30, "lineHeight": 38, "weight": 600, "letterSpacing": -0.01 },
      "heading-md": { "size": 24, "lineHeight": 32, "weight": 600, "letterSpacing": -0.01 },
      "heading-sm": { "size": 20, "lineHeight": 28, "weight": 600, "letterSpacing": 0 },
      "body-lg": { "size": 18, "lineHeight": 28, "weight": 400, "letterSpacing": 0 },
      "body-md": { "size": 16, "lineHeight": 24, "weight": 400, "letterSpacing": 0 },
      "body-sm": { "size": 14, "lineHeight": 20, "weight": 400, "letterSpacing": 0 },
      "label-md": { "size": 14, "lineHeight": 20, "weight": 500, "letterSpacing": 0 },
      "label-sm": { "size": 12, "lineHeight": 16, "weight": 500, "letterSpacing": 0.01 },
      "caption": { "size": 11, "lineHeight": 14, "weight": 400, "letterSpacing": 0.02 }
    }
  },
  "spacing": {
    "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "12": 48, "16": 64, "20": 80, "24": 96
  },
  "radius": { "none": 0, "sm": 4, "md": 8, "lg": 12, "xl": 16, "full": 9999 },
  "elevation": {
    "sm": "0 1px 2px rgba(15, 23, 42, 0.05)",
    "md": "0 4px 6px -1px rgba(15, 23, 42, 0.08), 0 2px 4px -2px rgba(15, 23, 42, 0.05)",
    "lg": "0 10px 15px -3px rgba(15, 23, 42, 0.08), 0 4px 6px -4px rgba(15, 23, 42, 0.05)",
    "xl": "0 20px 25px -5px rgba(15, 23, 42, 0.1), 0 8px 10px -6px rgba(15, 23, 42, 0.05)"
  },
  "grid": {
    "breakpoints": { "sm": 640, "md": 768, "lg": 1024, "xl": 1280, "2xl": 1536 },
    "columns": { "mobile": 4, "tablet": 8, "desktop": 12 },
    "gutter": { "mobile": 16, "tablet": 24, "desktop": 24 },
    "margin": { "mobile": 16, "tablet": 32, "desktop": 48 }
  },
  "components": [
    "Button", "IconButton", "Input", "Select", "Checkbox", "Radio", "Switch",
    "Badge", "Tag", "Avatar", "Tooltip", "Modal", "Toast", "Tabs",
    "TableRow", "Pagination", "Breadcrumb", "SidebarNavItem"
  ],
  "patterns": ["FormLayout", "PageHeader", "EmptyState", "DataTableToolbar"],
  "tokenNaming": {
    "color": "color/{mode}/{category}/{name}",
    "spacing": "space/{value}",
    "radius": "radius/{size}",
    "typography": "font/{role}/{property}"
  }
}
